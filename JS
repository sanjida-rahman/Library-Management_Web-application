async function loadBooks() {
  const data = await apiFetch("/books");
  const tbody = document.getElementById("books-table");
  tbody.innerHTML = "";
  const select = document.getElementById("issue-book");
  select.innerHTML = '<option value="">-- select book --</option>';

  data.forEach(b => {
    const pubName = b.publisher ? b.publisher.publisher_name : "—";
    tbody.innerHTML += `
      <tr>
        <td>${b.book_id}</td>
        <td>${b.book_name}</td>
        <td>${b.isbn}</td>
        <td>${b.date_of_publish ? b.date_of_publish.substring(0,10) : "—"}</td>
        <td>${b.genre || "—"}</td>
        <td>${pubName}</td>
        <td>
          <button class="action-btn edit-btn" onclick='editBook(${JSON.stringify(b)})'>Edit</button>
          <button class="action-btn delete-btn" onclick="deleteBook(${b.book_id})">Delete</button>
        </td>
      </tr>`;
    select.innerHTML += `<option value="${b.book_id}">${b.book_name}</option>`;
  });
}

function editBook(b) {
  document.getElementById("book-id").value = b.book_id;
  document.getElementById("book-name").value = b.book_name;
  document.getElementById("book-isbn").value = b.isbn;
  document.getElementById("book-date").value = b.date_of_publish ? b.date_of_publish.substring(0,10) : "";
  document.getElementById("book-genre").value = b.genre || "";
  document.getElementById("book-publisher").value = b.publisher_id;
