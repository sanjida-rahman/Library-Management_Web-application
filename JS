const API_BASE = "https://localhost:7001/api";

// If already logged in, skip straight to the right dashboard
(function redirectIfLoggedIn() {
  const session = getSession();
  if (session && session.role === "admin") window.location.href = "admin-dashboard.html";
  if (session && session.role === "member") window.location.href = "member-dashboard.html";
})();

function showError(msg) {
  const el = document.getElementById("auth-error");
  el.textContent = msg;
  el.classList.remove("hidden");
}
function clearError() {
  document.getElementById("auth-error").classList.add("hidden");
}

// ---------- Role tabs ----------
document.querySelectorAll(".role-tab-btn").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".role-tab-btn").forEach(b => b.classList.remove("active"));
    document.querySelectorAll(".auth-panel").forEach(p => p.classList.remove("active"));
    btn.classList.add("active");
    document.getElementById(`${btn.dataset.role}-panel`).classList.add("active");
    clearError();
  });
});

// ---------- Member: toggle login / register ----------
document.getElementById("show-register").addEventListener("click", e => {
  e.preventDefault();
  document.getElementById("member-login-form").classList.add("hidden");
  document.getElementById("member-register-form").classList.remove("hidden");
  document.getElementById("back-to-login-wrap").classList.remove("hidden");
  e.target.parentElement.classList.add("hidden");
  clearError();
});
document.getElementById("show-login").addEventListener("click", e => {
  e.preventDefault();
  document.getElementById("member-register-form").classList.add("hidden");
  document.getElementById("back-to-login-wrap").classList.add("hidden");
  document.getElementById("member-login-form").classList.remove("hidden");
  document.querySelector("#member-panel .auth-switch").classList.remove("hidden");
  clearError();
});

// ---------- Member login ----------
document.getElementById("member-login-form").addEventListener("submit", async e => {
  e.preventDefault();
  clearError();
  const payload = {
    emailOrName: document.getElementById("member-login-id").value,
    password: document.getElementById("member-login-password").value
  };
  try {
    const res = await fetch(`${API_BASE}/members/login`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload)
    });
    if (!res.ok) throw new Error("Invalid email/name or password");
    const data = await res.json();
    setSession({ role: "member", id: data.mem_id, name: data.full_name });
    window.location.href = "member-dashboard.html";
  } catch (err) {
    showError(err.message);
  }
});

