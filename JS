// ---------- Available books ----------
async function loadAvailable() {
  const data = await apiFetch("/issues/available-books");
  const tbody = document.getElementById("available-table");
  tbody.innerHTML = "";

  if (data.length === 0) {
    tbody.innerHTML = `<tr><td colspan="5">No books available right now.</td></tr>`;
    return;
  }

  data.forEach(b => {
    const pubName = b.publisher ? b.publisher.publisher_name : "—";
    tbody.innerHTML += `
      <tr>
        <td>${b.book_name}</td>
        <td>${b.isbn}</td>
        <td>${b.genre || "—"}</td>
        <td>${pubName}</td>
        <td><button class="action-btn return-btn" onclick="borrowBook(${b.book_id})">Borrow</button></td>
      </tr>`;
  });
}

async function borrowBook(bookId) {
  await apiFetch("/issues/self-issue", {
    method: "POST",
    body: JSON.stringify({ book_id: bookId, mem_id: SESSION.id })
  });
  toast("Book borrowed! Check 'My Loans'.");
  loadAvailable();
  loadMyLoans();
}

// ---------- My loans ----------
async function loadMyLoans() {
  const data = await apiFetch(`/issues/member/${SESSION.id}`);
  const tbody = document.getElementById("my-loans-table");
  tbody.innerHTML = "";

  if (data.length === 0) {
    tbody.innerHTML = `<tr><td colspan="5">You haven't borrowed any books yet.</td></tr>`;
    return;
  }

  data.forEach(i => {
    const bookName = i.book ? i.book.book_name : `#${i.book_id}`;
    tbody.innerHTML += `
      <tr>
        <td>${bookName}</td>
        <td>${i.date_of_issue ? i.date_of_issue.substring(0,10) : "—"}</td>
        <td>${i.return_date ? i.return_date.substring(0,10) : "—"}</td>
        <td>${i.returned_or_not ? "Returned" : "On loan"}</td>
        <td>${!i.returned_or_not ? `<button class="action-btn delete-btn" onclick="returnBook(${i.issue_id})">Return</button>` : "—"}</td>
      </tr>`;
  });
}

async function returnBook(issueId) {
  await apiFetch(`/issues/${issueId}/self-return`, {
    method: "PUT",
    body: JSON.stringify({ mem_id: SESSION.id })
  });
  toast("Book returned. Thanks!");
  loadMyLoans();
  loadAvailable();
}

// ---------- Init ----------
window.addEventListener("DOMContentLoaded", () => {
  SESSION = requireRole("member");
  if (!SESSION) return; // redirected to login

  loadAvailable();
  loadMyLoans();
});
