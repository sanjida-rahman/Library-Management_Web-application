// ============================================================
// Shared authentication / session helper.
// Include this BEFORE app.js / member.js on protected pages.
// ============================================================

const SESSION_KEY = "lms_session";

function getSession() {
  const raw = localStorage.getItem(SESSION_KEY);
  return raw ? JSON.parse(raw) : null;
}

function setSession(session) {
  localStorage.setItem(SESSION_KEY, JSON.stringify(session));
}

function clearSession() {
  localStorage.removeItem(SESSION_KEY);
}

// Call at the top of any protected page: requireRole("admin") or requireRole("member")
function requireRole(role) {
  const session = getSession();
  if (!session || session.role !== role) {
    window.location.href = "login.html";
    return null;
  }
  const welcome = document.getElementById("welcome-text");
  if (welcome) welcome.textContent = `Hi, ${session.name}`;
  return session;
}

document.addEventListener("DOMContentLoaded", () => {
  const logoutBtn = document.getElementById("logout-btn");
  if (logoutBtn) {
    logoutBtn.addEventListener("click", () => {
      clearSession();
      window.location.href = "login.html";
    });
  }
});

