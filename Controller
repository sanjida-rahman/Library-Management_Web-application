using LibraryApi.Data;
using LibraryApi.Models;
using Microsoft.AspNetCore.Mvc;
using Microsoft.EntityFrameworkCore;

namespace LibraryApi.Controllers
{
    [ApiController]
    [Route("api/members")]
    public class MembersController : ControllerBase
    {
        private readonly LibraryDbContext _db;
        public MembersController(LibraryDbContext db) => _db = db;

        [HttpGet]
        public async Task<ActionResult<IEnumerable<Member>>> GetAll() =>
            await _db.Members.ToListAsync();

        [HttpGet("{id}")]
        public async Task<ActionResult<Member>> GetById(int id)
        {
            var item = await _db.Members.FindAsync(id);
            return item is null ? NotFound() : item;
        }

        [HttpPost]
        public async Task<ActionResult<Member>> Create(Member input)
        {
            _db.Members.Add(input);
            await _db.SaveChangesAsync();
            return CreatedAtAction(nameof(GetById), new { id = input.Mem_id }, input);
        }

        [HttpPut("{id}")]
        public async Task<IActionResult> Update(int id, Member input)
        {
            if (id != input.Mem_id) return BadRequest();
            _db.Entry(input).State = EntityState.Modified;
            await _db.SaveChangesAsync();
            return NoContent();
        }

        [HttpDelete("{id}")]
        public async Task<IActionResult> Delete(int id)
        {
            var item = await _db.Members.FindAsync(id);
            if (item is null) return NotFound();
            _db.Members.Remove(item);
            await _db.SaveChangesAsync();
            return NoContent();
        }

        // Member registration (self sign-up)
        [HttpPost("register")]
        public async Task<ActionResult<Member>> Register(Member input)
        {
            var exists = await _db.Members.AnyAsync(m => m.Email == input.Email && input.Email != null);
            if (exists) return Conflict(new { message = "An account with this email already exists." });

            _db.Members.Add(input);
            await _db.SaveChangesAsync();
            return CreatedAtAction(nameof(GetById), new { id = input.Mem_id }, input);
        }

        // Member login
        [HttpPost("login")]
        public async Task<IActionResult> Login([FromBody] MemberLoginRequest req)
        {
            var member = await _db.Members.FirstOrDefaultAsync(m =>
                (m.Email == req.EmailOrName || m.Full_name == req.EmailOrName) && m.Password == req.Password);

            return member is null
                ? Unauthorized(new { message = "Invalid credentials" })
                : Ok(new { member.Mem_id, member.Full_name, member.Email });
        }
    }

    public class MemberLoginRequest
    {
        public string EmailOrName { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}

